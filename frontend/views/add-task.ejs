<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Add Task</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    /* 🌈 BACKGROUND */
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #667eea, #764ba2);
    }

    /* 🔥 NAVBAR */
    .topbar {
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(10px);
      padding: 14px 20px;
    }

    .brand {
      color: #fff;
      font-weight: bold;
      font-size: 18px;
      text-decoration: none;
    }

    .nav-link-custom {
      color: #fff !important;
      margin-left: 20px;
      text-decoration: none;
      transition: 0.3s;
    }

    .nav-link-custom:hover {
      color: #00f2fe !important;
    }

    /* 💎 CENTER */
    .center-box {
      min-height: calc(100vh - 60px);
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* ✨ CARD */
    .card-box {
      width: 420px;
      padding: 30px;
      border-radius: 15px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(15px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      color: white;
      transition: 0.3s;
    }

    .card-box:hover {
      transform: translateY(-5px);
    }

    h3 {
      font-weight: bold;
    }

    label {
      font-weight: 600;
      margin-bottom: 5px;
    }

    /* 🔥 INPUT */
    .form-control {
      border-radius: 8px;
      border: none;
      padding: 10px;
    }

    /* 🔘 3D BUTTON */
    .btn-3d {
      border: none;
      padding: 10px;
      border-radius: 8px;
      font-weight: bold;
      color: white;
      background: linear-gradient(45deg, #00c6ff, #0072ff);
      box-shadow: 0 5px 0 rgba(0,0,0,0.3);
      transition: 0.2s;
    }

    .btn-3d:hover {
      opacity: 0.9;
    }

    .btn-3d:active {
      transform: translateY(3px);
      box-shadow: 0 2px 0 rgba(0,0,0,0.3);
    }

    /* ⚡ ALERT */
    .alert {
      border-radius: 8px;
    }

  </style>
</head>

<body>

<nav class="topbar d-flex justify-content-between">
  <a href="/tasks" class="brand">To Do App</a>

  <div>
    <a href="/tasks" class="nav-link-custom">List</a>
    <a href="/tasks/add" class="nav-link-custom">Add Task</a>
    <a href="/logout" class="nav-link-custom">Logout</a>
  </div>
</nav>

<div class="center-box">

  <div class="card-box">

    <h3 class="text-center mb-3">✨ Add New Task</h3>

    <!-- FLASH -->
    <% if (message && message.length > 0) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/tasks/add" method="POST">

      <!-- TITLE -->
      <div class="mb-2">
        <label>Title</label>
        <input type="text" name="title" class="form-control" required>
      </div>

      <!-- DESCRIPTION -->
      <div class="mb-2">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="3" required></textarea>
      </div>

      <!-- PRIORITY -->
      <div class="mb-2">
        <label>Priority</label>
        <select name="priority" class="form-control">
          <option value="low">Low 🟢</option>
          <option value="medium">Medium 🟡</option>
          <option value="high">High 🔴</option>
        </select>
      </div>

      <!-- DUE DATE -->
      <div class="mb-2">
        <label>Due Date</label>
        <input type="date" name="dueDate" class="form-control">
      </div>

      <button class="btn-3d w-100 mt-3">🚀 Add Task</button>

    </form>

  </div>

</div>

</body>
</html>