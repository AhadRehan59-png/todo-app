<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sign Up</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- ICONS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>

body{
  background: linear-gradient(135deg, #667eea, #764ba2);
  font-family: Arial;
  margin: 0;
}

/* NAVBAR */
.navbar{
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(10px);
}

.navbar-brand{
  color:white !important;
  font-weight:bold;
  font-size:18px;
}

/* CENTER */
.center-box{
  min-height: 100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding: 20px; /* ✅ mobile spacing */
}

/* CARD */
.card{
  width: 100%;
  max-width: 400px;  /* ✅ responsive width */
  padding:25px;
  border-radius:15px;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(15px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  color:white;
}

h3{
  font-weight:bold;
  font-size: 22px;
}

/* INPUT */
.form-control{
  border-radius:8px;
  border:none;
  margin-bottom:10px;
  padding: 10px;
  font-size: 14px;
}

.form-control:focus{
  box-shadow: 0 0 6px #00ffcc;
}

/* PASSWORD FIELD */
.password-box{
  position: relative;
}

.password-box i{
  position: absolute;
  right: 12px;
  top: 38px;
  cursor: pointer;
  color: #333;
}

/* BUTTON */
.btn-custom{
  background: linear-gradient(45deg, #00ffcc, #00b3ff);
  border:none;
  color:black;
  font-weight:bold;
  padding:10px;
  border-radius:8px;
  transition:0.3s;
}

.btn-custom:hover{
  transform:scale(1.05);
  box-shadow: 0 0 10px #00ffcc;
}

/* LINK */
.login-link{
  color:#00ffcc;
  text-decoration:none;
}

.login-link:hover{
  text-decoration:underline;
}

/* 📱 MOBILE FIX */
@media (max-width: 480px){

  .card{
    padding:20px;
  }

  h3{
    font-size:18px;
  }

  .form-control{
    font-size:13px;
  }

  .btn-custom{
    padding:8px;
    font-size:14px;
  }

}

</style>

</head>

<body>

<nav class="navbar navbar-dark">
<div class="container-fluid">
<a class="navbar-brand">🚀 To Do App</a>
</div>
</nav>

<div class="center-box">

<div class="card">

<h3 class="text-center mb-4">🚀 Sign Up</h3>

<form action="/signup" method="POST">

<div class="mb-2">
<label>Name</label>
<input type="text" name="name" class="form-control" placeholder="Enter your name" required>
</div>

<div class="mb-2">
<label>Email</label>
<input type="email" name="email" class="form-control" placeholder="Enter email" required>
</div>

<!-- PASSWORD -->
<div class="mb-2 password-box">
<label>Password</label>
<input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required>
<i class="bi bi-eye-slash" onclick="togglePassword()"></i>
</div>

<button class="btn-custom w-100 mt-3">Create Account 🚀</button>

</form>

<p class="text-center mt-3">
Already have account? 
<a href="/login" class="login-link">Login</a>
</p>

</div>

</div>

<script>
function togglePassword() {
  const input = document.getElementById("password");
  const icon = document.querySelector(".password-box i");

  if (input.type === "password") {
    input.type = "text";
    icon.classList.replace("bi-eye-slash", "bi-eye");
  } else {
    input.type = "password";
    icon.classList.replace("bi-eye", "bi-eye-slash");
  }
}
</script>

</body>
</html>