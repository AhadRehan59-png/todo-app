<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Task</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    body {
      background: linear-gradient(135deg, #667eea, #764ba2);
      font-family: Arial;
    }

    /* NAVBAR */
    .topbar {
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(10px);
      padding: 14px 18px;
    }

    .brand {
      color: white;
      font-weight: bold;
      font-size: 18px;
      text-decoration: none;
    }

    .nav-link-custom {
      color: white !important;
      margin-left: 20px;
      text-decoration: none;
      transition: 0.3s;
    }

    .nav-link-custom:hover {
      color: #00ffcc !important;
    }

    /* CENTER CARD */
    .center-box {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .card-box {
      width: 420px;
      padding: 28px;
      border-radius: 15px;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(15px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      color: white;
    }

    h3 {
      font-weight: bold;
    }

    label {
      font-weight: 600;
      margin-bottom: 5px;
    }

    .form-control, .form-select {
      border-radius: 8px;
      border: none;
      box-shadow: none;
    }

    .form-control:focus {
      box-shadow: 0 0 5px #00ffcc;
    }

    /* BUTTON */
    .btn-custom {
      background: linear-gradient(45deg, #00ffcc, #00b3ff);
      border: none;
      color: black;
      font-weight: bold;
      padding: 10px;
      border-radius: 8px;
      transition: 0.3s;
    }

    .btn-custom:hover {
      transform: scale(1.05);
      box-shadow: 0 0 10px #00ffcc;
    }

  </style>
</head>

<body>

<nav class="topbar d-flex justify-content-between">
  <a href="/tasks" class="brand">To Do App</a>

  <div>
    <a href="/tasks" class="nav-link-custom">List</a>
    <a href="/tasks/add" class="nav-link-custom">Add Task</a>
    <a href="/logout" class="nav-link-custom">Logout</a>
  </div>
</nav>

<div class="center-box">

  <div class="card-box">

    <h3 class="text-center mb-3">✏️ Edit Task</h3>

    <form method="POST" action="/tasks/edit/<%= task._id %>">

      <!-- TITLE -->
      <div class="mb-2">
        <label>Title</label>
        <input type="text" name="title" value="<%= task.title %>" class="form-control" required>
      </div>

      <!-- DESCRIPTION -->
      <div class="mb-2">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="3" required><%= task.description %></textarea>
      </div>

      <!-- STATUS -->
      <div class="mb-2">
        <label>Status</label>
        <select name="status" class="form-control">
          <option value="pending" <%= task.status==='pending'?'selected':'' %>>⏳ Pending</option>
          <option value="completed" <%= task.status==='completed'?'selected':'' %>>✅ Completed</option>
        </select>
      </div>

      <!-- PRIORITY -->
      <div class="mb-2">
        <label>Priority</label>
        <select name="priority" class="form-control">
          <option value="low" <%= task.priority==='low'?'selected':'' %>>🟢 Low</option>
          <option value="medium" <%= task.priority==='medium'?'selected':'' %>>🟡 Medium</option>
          <option value="high" <%= task.priority==='high'?'selected':'' %>>🔴 High</option>
        </select>
      </div>

      <!-- DUE DATE -->
      <div class="mb-2">
        <label>Due Date</label>
        <input 
          type="date" 
          name="dueDate" 
          class="form-control"
          value="<%= task.dueDate ? new Date(task.dueDate).toISOString().split('T')[0] : '' %>"
        >
      </div>

      <button class="btn-custom w-100 mt-3">Update Task 🚀</button>

    </form>

  </div>

</div>

</body>
</html>